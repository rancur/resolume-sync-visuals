# API Keys for video generation
# Set these to your actual API keys (or use `op run` with 1Password references)

# OpenAI (DALL-E 3 for image generation)
OPENAI_API_KEY=your_openai_api_key_here

# Replicate (optional - for Flux/SDXL image generation)
# REPLICATE_API_TOKEN=your_replicate_token_here

# fal.ai (Flux LoRA keyframes + Kling video generation)
FAL_KEY=your_fal_api_key_here

# Network — adjust to match your local setup
LEXICON_HOST=127.0.0.1
LEXICON_PORT=48624
NAS_HOST=your_nas_ip_here
NAS_SSH_PORT=7844
NAS_USER=your_nas_username
RESOLUME_HOST=127.0.0.1
RESOLUME_PORT=8080

# App
LOG_RETENTION_DAYS=365
MAX_CONCURRENT_JOBS=2
DEFAULT_VIDEO_MODEL=kling-v1
DEFAULT_BRAND=example
